library(ElemStatLearn)
data(SAheart)
set.seed(8484)
train = sample(1:dim(SAheart)[1],size=dim(SAheart)[1]/2,replace=F)
trainSA = SAheart[train,]
testSA = SAheart[-train,]
set.seed(13234)
summary(trainSA)
modFit <- train(chd ~ age + alcohol + obesity + typea + tobacco + ldl, method="glm, family="binomial", data = trainSA)
modFit <- train(chd ~ age + alcohol + obesity + typea + tobacco + ldl, method="glm", family="binomial", data = trainSA)
missClass = function(values,prediction){sum(((prediction > 0.5)*1) != values)/length(values)}
?predict
predict(modFit$finalModel, newdata = trainSA, type = "response")
predictresponsetrain <- predict(modFit$finalModel, newdata = trainSA, type = "response")
